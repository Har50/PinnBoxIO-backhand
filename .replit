VITE_CLERK_PUBLISHABLE_KEY = "pk_test_dGhhbmtmdWwtc3dpZnQtNDIuY2xlcmsuYWNjb3VudHMuZGV2JA"
LINKEDIN_REDIRECT_BASE_URL = "https://pinnboxio.net"

[userenv.production]
PUBLIC_URL = "https://pinn-box-io.replit.app"
