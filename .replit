modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Mobile Production Build"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Android Binary Build"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "iOS Binary Build"

[[workflows.workflow]]
name = "Mobile Production Build"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/artifacts/mobile && pnpm dlx eas-cli@latest update --branch production --message 'Production update' --non-interactive"

[[workflows.workflow]]
name = "Android Binary Build"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/artifacts/mobile && pnpm dlx eas-cli@latest build --platform android --profile production --non-interactive --wait && pnpm dlx eas-cli@latest submit --platform android --profile production --non-interactive --latest"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "iOS Binary Build"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/artifacts/mobile && pnpm dlx eas-cli@latest build --platform ios --profile production --non-interactive --wait && pnpm dlx eas-cli@latest submit --platform ios --profile production --non-interactive --latest"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["revenuecat:1.0.0", "stripe:1.0.0", "google-mail:1.0.0", "outlook:1.0.0", "notion:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
REVENUECAT_PROJECT_ID = "projce947fce"
REVENUECAT_TEST_STORE_APP_ID = "app3bd2b9783a"
