{
  "expo": {
    "name": "PinnboxIO",
    "slug": "pinnboxio-mobile",
    "owner": "plav",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pinnboxio",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pinnboxio.mobile",
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "PinnboxIO uses your microphone so you can dictate messages and commands to the AI assistant.",
        "NSCameraUsageDescription": "PinnboxIO uses your camera so you can scan and upload documents."
      },
      "buildNumber": "13"
    },
    "android": {
      "package": "com.pinnboxio.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "cameraPermission": "PinnboxIO uses your camera so you can scan and upload documents."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "PinnboxIO uses your microphone so you can dictate messages and commands to the AI assistant."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "marketingUrl": "https://pinnboxio.net",
    "privacyPolicyUrl": "https://pinnboxio.net/privacy",
    "extra": {
      "eas": {
        "projectId": "fca24fe7-c2c3-40e4-a330-c783871ef968"
      }
    }
  }
}
