{
  "expo": {
    "name": "PinnboxIO",
    "slug": "pinnboxio-mobile",
    "owner": "harshdev86",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pinnboxio",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pinnboxio.mobile",
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "PinnboxIO uses your microphone so you can dictate messages and commands to the AI assistant.",
        "NSCameraUsageDescription": "PinnboxIO uses your camera so you can scan and upload documents."
      },
      "buildNumber": "37"
    },
    "android": {
      "package": "com.pinnboxio.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "versionCode": 23
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "cameraPermission": "PinnboxIO uses your camera so you can scan and upload documents."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "PinnboxIO uses your microphone so you can dictate messages and commands to the AI assistant."
        }
      ],
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "packagingOptions": {
              "pickFirsts": [
                "META-INF/versions/9/OSGI-INF/MANIFEST.MF"
              ],
              "excludes": [
                "META-INF/versions/9/OSGI-INF/MANIFEST.MF"
              ]
            }
          }
        }
      ],
      "./plugins/withAndroidPackagingFix"
    ],
    "updates": {
      "url": "https://u.expo.dev/c34b27ee-d647-4e3c-b089-6088b3549bc1",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "c34b27ee-d647-4e3c-b089-6088b3549bc1"
      },
      "router": {
        "origin": "https://replit.com/"
      }
    }
  }
}
